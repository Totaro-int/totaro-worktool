    "check:structure": "tsx scripts/check-structure.ts",
    "check:unused-deps": "tsx scripts/check-unused-deps.ts",
    "check:large-files": "tsx scripts/check-large-files.ts",
    "check:drift": "tsx scripts/check-drift.ts",
    "sync:naver": "tsx scripts/sync-naver-commerce.ts",
    "sync:chat": "node scripts/chat-raw-uploader.mjs",
    "summarize:chat": "node scripts/summarize-chat-raw.mjs",
    "status": "node scripts/status.mjs",
    "check:all": "npm run format:check && npm run lint && npm run check:structure",
    "clean": "npm run check:unused-deps && npm run check:large-files && npm run check:drift",
    "prepare": "husky"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.3",
