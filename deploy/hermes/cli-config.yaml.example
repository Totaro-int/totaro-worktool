# ─────────────────────────────────────────────────────────────
# Hermes Agent — 토타로 에이전트 직원용 설정 템플릿
# 위치: VM 의 ~/.hermes/config.yaml 로 복사 후 <...> 채우기
# 참고: docs/hermes-deploy.md
# ─────────────────────────────────────────────────────────────

# 모델 — Gemini 를 OpenAI 호환 엔드포인트로 사용 (무료 쿼터)
model:
  provider: "custom"
  base_url: "https://generativelanguage.googleapis.com/v1beta/openai"
  model: "gemini-2.5-flash"
  api_key: "<GEMINI_API_KEY>"   # https://aistudio.google.com/apikey
  # Gemini 호환 이슈 시 폴백: OpenRouter 경유
  # provider: "custom"
  # base_url: "https://openrouter.ai/api/v1"
  # model: "google/gemini-2.5-flash"
  # api_key: "<OPENROUTER_API_KEY>"

# 회사 두뇌 연결 — 토타로 워크툴 MCP (HTTP)
# 에이전트가 쓸 수 있는 도구: mailroom_search/read, folder_browse,
# memory_write/search, label_list/attach, entity_link/search,
# tasks_list/create, agent_actions_recent, github_* 등
mcp_servers:
  totaro:
    url: "https://totaro-worktool.vercel.app/api/mcp"
    headers:
      Authorization: "Bearer <MCP_BEARER_TOKEN>"   # Vercel env 의 MCP_BEARER_TOKEN 과 동일 값
    timeout: 120

# 에이전트 신원 — 시스템 프롬프트에 주입할 역할 (예: 김사현)
# Hermes 의 persona/system prompt 설정 위치는 버전에 따라 다름:
#   hermes profile 또는 ~/.hermes/profiles/<name>/ 에 역할 정의.
# 핵심 규칙 (프롬프트에 반드시 포함):
#   1) 너는 토타로 마케팅부 에이전트 '김사현'. MCP 도구 호출 시 agent 파라미터는 항상 "kim-sahyun".
#   2) 조사로 알게 된 재사용 가치 있는 사실은 memory_write 로 저장 (출처 포함).
#   3) 문서/태스크 분류는 label_list 로 통제 어휘 확인 후 label_attach.
#   4) 새 거래처·제품·지원사업 발견 시 entity_link 로 등록.
#   5) 보고는 한국어, 다이제스트는 5줄 요약 + 콘텐츠 소재 3개 제안.
