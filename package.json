    "@typescript-eslint/parser": "^8.59.3",
    "depcheck": "^1.4.7",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "eslint-plugin-import": "^2.32.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.1",
    "typescript": "^5"
