# ==============================================
# 환경 변수 설정 가이드
# ==============================================
#
# 🔧 설정 방법:
# 1. 이 파일을 복사해서 .env.local 파일을 만드세요
#    cp .env.local.example .env.local
#
# 2. 아래 값들을 실제 값으로 바꾸세요
#
# ⚠️ 중요: .env.local 파일은 절대 Git에 커밋하지 마세요!
# ==============================================

# ----------------------------------------------
# 🗄️ Supabase 설정 (필수)
# ----------------------------------------------
#
# 📍 발급 방법:
# 1. https://supabase.com 접속
# 2. "New Project" 클릭
# 3. 프로젝트 이름, 비밀번호, 지역 설정
# 4. Settings → API 메뉴로 이동
# 5. "Project URL"과 "anon/public" 키 복사
#
# 📌 anon key는 공개되어도 안전합니다 (RLS로 보호됨)
# 📌 클라이언트 코드에서 사용 가능

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.ey...

# ----------------------------------------------
# 🚀 배포 사이트 주소 (선택)
# ----------------------------------------------
#
# 로컬 개발: 비워두면 자동으로 http://localhost:3000 사용
# 프로덕션: Vercel 배포 후 실제 도메인 입력
#
# 예시:
# - https://totaro-worktool.vercel.app
# - https://work.totaro.com

NEXT_PUBLIC_SITE_URL=

# ----------------------------------------------
# 🔐 Supabase Service Role Key (선택)
# ----------------------------------------------
#
# ⚠️ 매우 중요: 이 키는 모든 RLS를 우회합니다!
# ⚠️ 서버 사이드에서만 사용하세요 (절대 클라이언트 노출 금지)
# ⚠️ 일반적으로 필요하지 않습니다
#
# 사용 예시:
# - 관리자 전용 작업
# - 배치 작업
# - 데이터 마이그레이션
#
# 발급: Supabase → Settings → API → "service_role" 키

# Honeypot 로깅은 RLS 우회가 필요하므로 service_role 키 필수.
# 발급: Supabase Dashboard → Settings → API → "service_role" 키 복사
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.ey...


# ==============================================
# 추가 API (필요한 경우에만 설정)
# ==============================================

# ----------------------------------------------
# 🤖 AI 직원 — 답변 생성 (기본: Google Gemini, 추가 키 불필요)
# ----------------------------------------------
#
# /assistant (AI 직원) 의 답변 생성 경로 (위에서부터 되는 걸 사용):
#   1) Google Gemini (Vertex AI) — Drive 와 "같은" GOOGLE_SERVICE_ACCOUNT_JSON 재사용 ✅
#      → 새 API 키 불필요, 현금 0(GCP 크레딧), Vercel 서버리스에서도 동작. (기본 경로)
#   2) ANTHROPIC_API_KEY 가 있으면 → Anthropic API (선택, 위가 안 될 때 폴백)
#   3) 둘 다 없으면 → 로컬 `claude` CLI (개발자 Mac 에서만 동작)
#   4) 모두 안 되면 → 답변 없이 관련 자료 카드만 보여주는 폴백 모드
#
# 즉, GOOGLE_SERVICE_ACCOUNT_JSON 만 있으면 배포 사이트에서 AI 직원이 답변까지 합니다.
# (임베딩 검색을 켤 때 필요한 "Vertex AI API 활성화 + Vertex AI User 역할" 이 그대로 재사용됨)
#
# Gemini 답변 모델 (선택, 기본: 빠르고 저렴한 gemini-2.5-flash).
# 더 높은 품질을 원하면 gemini-2.5-pro 로 변경(비용 더 높음).
# GOOGLE_VERTEX_GEN_MODEL=gemini-2.5-flash
#
# --- (선택) Anthropic 으로도 답변 가능 — Gemini 가 안 될 때의 폴백 ---
# 📍 발급: https://console.anthropic.com → Settings → API Keys → "Create Key"
# 📌 서버 사이드에서만 사용 (NEXT_PUBLIC_ 접두어 절대 붙이지 말 것)
# 📌 사용량만큼 과금됨 — Anthropic 콘솔에서 예산 한도 설정 권장
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ----------------------------------------------
# 🔎 AI 직원 — 의미(임베딩) 검색 (선택, Google Vertex AI)
# ----------------------------------------------
#
# AI 직원의 자료 검색은 3단으로 폴백합니다(위에서부터 되는 걸 사용):
#   1) 의미 검색(임베딩) — 아래 설정 + 백필이 끝났을 때 ✅ (제일 똑똑함)
#   2) 트라이그램(글자 유사도) — supabase/assistant-search.sql 만 실행하면 동작
#   3) 키워드 매칭 — 아무 설정 없어도 항상 동작(기본)
# → 임베딩을 안 켜도 자동으로 2)·3) 으로 내려가서 절대 안 깨집니다.
#
# 💰 비용: Drive 와 "같은" 서비스 계정(GOOGLE_SERVICE_ACCOUNT_JSON)을 재사용하므로
#         새 API 키가 필요 없습니다. 사용량은 GCP Cloud 크레딧으로 청구(현금 0).
#
# 📍 켜는 방법(3단계):
#   1) Supabase SQL Editor 에서 supabase/assistant-embeddings.sql 실행
#   2) GCP 콘솔: Vertex AI API 활성화 + 서비스 계정에 "Vertex AI User" 역할 부여
#   3) 터미널에서 한 번: npm run embed:backfill  (기존 문서 일괄 임베딩)
#
# 아래 3개는 모두 "선택" — 기본값으로 충분하면 비워두세요.
#
# 임베딩 모델 (기본: text-multilingual-embedding-002, 다국어 768차원).
# 모델을 바꾸면 assistant-embeddings.sql 의 vector(768) 차원도 함께 바꿔야 함.
# GOOGLE_VERTEX_EMBED_MODEL=text-multilingual-embedding-002
#
# Vertex AI 리전 (기본: us-central1).
# GOOGLE_VERTEX_LOCATION=us-central1
#
# GCP 프로젝트 ID (기본: 서비스 계정 JSON 의 project_id 자동 사용).
# 크레딧이 다른 프로젝트에 있으면 그 프로젝트 ID 를 여기에 지정.
# GOOGLE_VERTEX_PROJECT=my-gcp-project-id

# ----------------------------------------------
# 📧 이메일 전송 (선택)
# ----------------------------------------------
#
# Supabase Auth가 기본 이메일을 보내지만,
# 커스텀 이메일이 필요하면 다음 중 하나 사용:
#
# SendGrid: https://sendgrid.com
# Resend: https://resend.com
# AWS SES: https://aws.amazon.com/ses

# SENDGRID_API_KEY=SG.xxxxxxxx
# RESEND_API_KEY=re_xxxxxxxx

# ----------------------------------------------
# 🖼️ 파일 스토리지 (선택)
# ----------------------------------------------
#
# Supabase Storage가 기본이지만,
# AWS S3나 Cloudflare R2를 추가로 사용할 수 있습니다

# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=wJalr...
# AWS_S3_BUCKET=my-bucket
# AWS_REGION=ap-northeast-2

# ----------------------------------------------
# 🔑 소셜 로그인 (선택)
# ----------------------------------------------
#
# Google OAuth:
# 1. https://console.cloud.google.com
# 2. API 및 서비스 → 사용자 인증 정보
# 3. OAuth 2.0 클라이언트 ID 생성
#
# GitHub OAuth:
# 1. https://github.com/settings/developers
# 2. New OAuth App

# GOOGLE_CLIENT_ID=123456789-xxxxxxxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxx
# GITHUB_CLIENT_ID=Iv1.xxxxxxxx
# GITHUB_CLIENT_SECRET=xxxxxxxx

# ----------------------------------------------
# 📊 분석 및 모니터링 (선택)
# ----------------------------------------------
#
# Google Analytics:
# https://analytics.google.com
#
# Sentry (에러 추적):
# https://sentry.io

# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# SENTRY_DSN=https://xxx@sentry.io/xxx


# ==============================================
# 개발 환경 설정
# ==============================================

# 개발 서버 포트 (기본: 3000)
# PORT=3000

# 로깅 레벨
# LOG_LEVEL=debug


# ==============================================
# 🌍 환경별 설정 가이드
# ==============================================
#
# 로컬 개발 (Development):
#   ✅ .env.local 파일 사용
#   ✅ 개발용 Supabase 프로젝트 권장
#   ✅ NEXT_PUBLIC_SITE_URL 비워둠
#
# 스테이징 (Preview):
#   ✅ Vercel 대시보드 → Environment Variables
#   ✅ "Preview" 환경에 설정
#   ✅ 스테이징용 Supabase 프로젝트 사용
#
# 프로덕션 (Production):
#   ✅ Vercel 대시보드 → Environment Variables
#   ✅ "Production" 환경에만 설정
#   ✅ 프로덕션 Supabase 프로젝트 사용
#   ✅ 반드시 HTTPS 도메인 사용
#
# ==============================================

# 💡 도움말:
# - Supabase 설정: docs/deployment.md 참조
# - 환경 변수 관리: docs/development.md 참조
